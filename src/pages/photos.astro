---
import Layout from "@layouts/Layout.astro";
import Nav from "@components/Nav.astro";
import MediaImage from "@components/MediaImage.astro";
import photos from "@app/data/photos.json";
import { getBlurhash } from "@utils/blurhash";

interface Photo {
  url: string;
  thumbnail: string;
  filename: string;
  metadata: {
    width: number;
    height: number;
    iso: number;
    aperture: number;
    focalLength: number;
    model: string;
  };
}
const photosTyped = photos as Photo[];

const blurhashes: Record<string, string> = {};
for (const photo of photosTyped) {
  blurhashes[photo.url] = await getBlurhash(photo.url);
}

const CAMERA_MODEL_OVERRIDE: Record<string, string> = {
  "ILCE-7CM2": "Sony a7CII",
};

function getAperture(aperture: number) {
  return Number.isInteger(aperture) ? aperture : aperture.toFixed(1);
}

function getModel(model: string) {
  return CAMERA_MODEL_OVERRIDE[model] || model;
}
---

<Layout title="Photos" compactTop>
  <Nav />
  <h1 class="text-4xl mb-3">Photos</h1>
  <div class="md:columns-3 gap-3 mb-2">
    {
      photosTyped.map((photo) => {
        const { iso, aperture, focalLength } = photo.metadata;
        return (
          <figure
            class="photo-item group relative mb-2 break-inside-avoid cursor-pointer"
            data-full={photo.url}
            data-alt={photo.filename}
            data-blurhash={blurhashes[photo.url]}
          >
            <MediaImage
              class="rounded-md"
              src={photo.url}
              thumbnail={photo.thumbnail}
              alt={photo.filename}
              width={photo.metadata.width}
              height={photo.metadata.height}
            />
            <figcaption class="absolute bottom-0 left-0 right-0 px-2 py-3 text-white text-sm bg-linear-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-b-md">
              <div class="float-left flex gap-3">
                {iso && <span>ISO {iso}</span>}
                {aperture && <span>f/{getAperture(aperture)}</span>}
                {focalLength && <span>{Math.round(focalLength)}mm</span>}
              </div>
              <div class="float-right flex gap-3">
                {photo.metadata.model && (
                  <span>{getModel(photo.metadata.model)}</span>
                )}
              </div>
            </figcaption>
          </figure>
        );
      })
    }
  </div>

  <dialog
    id="lightbox"
    aria-modal="true"
    role="dialog"
    class="fixed inset-0 m-auto max-w-[95vw] max-h-[95vh] w-fit bg-transparent border-none p-0 backdrop:bg-black/80 backdrop:cursor-pointer"
  >
    <button
      id="lightbox-close"
      aria-label="Close"
      class="fixed top-4 right-4 bg-transparent border-none text-white text-4xl leading-none cursor-pointer py-1 px-2"
      >&times;</button
    >
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="block max-w-[95vw] max-h-[95vh] object-contain"
    />
  </dialog>
</Layout>

<style is:global>
  @reference "tailwindcss";
  body {
    @apply mx-auto md:max-w-[75%] max-w-[90%];
  }
</style>

<script>
  import { blurhashToCssGradientString } from "@unpic/placeholder";
  const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;

  function close() {
    lightbox.close();
    lightboxImg.src = "";
    lightboxImg.alt = "";
    lightbox.style.background = "";
  }

  // Only enable lightbox on devices with a fine pointer
  if (window.matchMedia("(pointer: fine)").matches) {
    document.querySelectorAll<HTMLElement>(".photo-item").forEach((item) => {
      item.addEventListener("click", () => {
        lightboxImg.src = item.dataset.full!;
        lightboxImg.alt = item.dataset.alt || "";
        lightbox.style.background = blurhashToCssGradientString(
          item.dataset.blurhash!,
        );
        lightbox.showModal();
      });
    });
  }

  document.getElementById("lightbox-close")!.addEventListener("click", () => {
    close();
  });

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) close();
  });
</script>
