---
import { getBlurhash } from "@app/utils/blurhash";
import { Image } from "astro:assets";
import { blurhashToCssGradientString } from "@unpic/placeholder";

interface Props {
  src: string;
  alt?: string;
  width: number;
  height: number;
  thumbnail?: string;
  class?: string;
}

const props = Astro.props;
const thumbnailUrl = props.thumbnail || props.src;
const blurhash = await getBlurhash(thumbnailUrl);
const gradient = blurhashToCssGradientString(blurhash);
---

<Image
  class={`w-full h-full object-cover rounded-md ${props.class || ""}`}
  src={thumbnailUrl}
  alt={props.alt || ""}
  width={props.width}
  height={props.height}
  loading="lazy"
  style={{
    background: gradient,
  }}
/>
