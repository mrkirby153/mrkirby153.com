---
import { getBlurhash } from "@app/utils/blurhash";
import { Image } from "astro:assets";
import { blurhashToCssGradientString } from "@unpic/placeholder";

interface Props {
  src: string;
  alt?: string;
  width: number;
  height: number;
  class?: string;
  quality?: number;
}

const props = Astro.props;
const blurhash = await getBlurhash(props.src);
const gradient = blurhashToCssGradientString(blurhash);
---

<Image
  class={`w-full h-full object-cover rounded-md ${props.class || ""}`}
  src={props.src}
  alt={props.alt || ""}
  width={props.width}
  height={props.height}
  loading="lazy"
  style={{
    background: gradient,
  }}
  quality={props.quality || 80}
  format="webp"
/>
